{
  "name": "legal-ai-frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix:wave1": "eslint --ext .js,.jsx,.ts,.tsx app lib --fix --rule 'react/no-unescaped-entities:error'",
    "lint:wave2:hooks": "eslint --ext .js,.jsx,.ts,.tsx app lib --max-warnings=0 --rule 'react-hooks/exhaustive-deps:error'",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "precheck:lockfile": "node scripts/check-lockfile-sync.cjs",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test e2e/smoke-analyze-generate.spec.ts",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "autoprefixer": "^10.4.19",
    "next": "^14.2.35",
    "postcss": "^8.4.38",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.16.5",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "volta": {
    "node": "20.19.0"
  }
}
