# ─────────────────────────────────────────────────────────────────────────────
# Legal AI Platform — Docker environment template
#
# Copy this file to .env.local and fill in real values:
#   cp .env.docker .env.local
#
# Then start the stack:
#   docker compose --env-file .env.local up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=secret

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set to "true" to skip Supabase auth and use a built-in dev user
# (dev@legal-ai.local / dev-token) — safe for local testing only
ALLOW_DEV_AUTH=true

# JWT signing key (can be any random string locally)
SECRET_KEY=change-me-in-production

# ── Supabase (optional — required only when ALLOW_DEV_AUTH=false) ─────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ── AI providers (at least one required for real document generation) ─────────
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Or use OpenAI as a fallback
OPENAI_API_KEY=

# ── LiqPay payments (optional) ────────────────────────────────────────────────
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
