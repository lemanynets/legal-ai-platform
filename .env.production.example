# === PRODUCTION CONFIGURATION (RAILWAY / VPS) ===
# This file contains placeholders for production secrets.
# COPY THIS TO .env IN PRODUCTION AND FILL ALL VALUES.

# 1. Base URLs
BACKEND_PORT=8000
FRONTEND_PORT=3000
# Railway typically provides a dynamic URL. Point this to your backend domain.
NEXT_PUBLIC_API_BASE_URL=https://legal-ai-backend.up.railway.app

# 2. Database (PostgreSQL)
# Use your Supabase Pooling URL or Railway Postgres URL
DATABASE_URL=postgresql+psycopg://postgres:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# 3. Security (CRITICAL)
# DISABLE development auth in production!
ALLOW_DEV_AUTH=false
NEXT_PUBLIC_ALLOW_DEV_AUTH=false
# Whitelist your production frontend domains
ALLOWED_ORIGINS=https://legal-ai-frontend.up.railway.app,https://your-custom-domain.com

# 4. Rate Limiting
# Protect API from abuse. Format: "count/interval" (e.g., "100/minute")
RATE_LIMIT_DEFAULT=60/minute

# 5. AI Providers
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-prod-placeholder-fill-me
OPENAI_MODEL=gpt-4o-mini

# 6. Cloud Storage & Auth (Supabase)
# Required for persistent file storage of generated documents and real Auth
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-settings
SUPABASE_STORAGE_BUCKET=legal-documents

# 7. Payments (LiqPay)
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SERVER_URL=https://legal-ai-backend.up.railway.app/api/billing/liqpay-callback
LIQPAY_RESULT_URL=https://legal-ai-frontend.up.railway.app/dashboard/billing/success
LIQPAY_CHECKOUT_URL=https://www.liqpay.ua/api/3/checkout

# 8. External APIs
OPENDATABOT_API_KEY=

# 9. E-Court (court.gov.ua) Integration
# Register your organisation at https://court.gov.ua to obtain credentials.
# In production set TEST_MODE=false and point to the production API.
COURT_GOV_UA_TEST_MODE=false
COURT_GOV_UA_API_BASE=https://api-corp.court.gov.ua
COURT_GOV_UA_CLIENT_ID=
COURT_GOV_UA_CLIENT_SECRET=

# 10. Document Settings
DOCUMENT_STORAGE_ROOT=data/generated_exports
STRICT_FILING_MODE=true
